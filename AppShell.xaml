<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="AppMeteoMAUI.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:AppMeteoMAUI"
    Title="MeteorApp">

    <Shell.TitleView>
        <Grid>
            <Label Text="MeteorApp" HorizontalOptions="Center" VerticalOptions="Center" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontSize="24" />
        </Grid>
    </Shell.TitleView>

    

    <ShellContent
        Title="MeteorApp"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

</Shell>
